<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="com.bookstore.controller.DashboardController" xmlns="http://javafx.com/javafx/25.0.2" xmlns:fx="http://javafx.com/fxml/1" style="-fx-background-color: #f5f6fa; -fx-padding: 20;">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 20 0 20; -fx-background-radius: 10;">
            <children>
                <Label text="TỔNG QUAN" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox prefHeight="200.0" spacing="20" style="-fx-padding: 20;">
            <children>
                <VBox prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: #3498db; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label text="Tổng sách" textFill="white" />
                        <Label fx:id="lblTotalBooks" text="0" textFill="white">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: #27ae60; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label text="Khách hàng" textFill="white" />
                        <Label fx:id="lblTotalCustomers" text="0" textFill="white">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label text="Hóa đơn hôm nay" textFill="white" />
                        <Label fx:id="lblTotalInvoicesToday" text="0" textFill="white">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: #f39c12; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label text="Doanh thu hôm nay" textFill="white" />
                        <Label fx:id="lblRevenueToday" text="0 ₫" textFill="white">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
