<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.controller.InvoiceController">
    <children>
        <VBox spacing="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: white; -fx-padding: 0 20 0 20;">
                    <children>
                        <Label text="QUẢN LÝ HÓA ĐƠN" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
                    <children>
                        <TextField fx:id="txtSearch" prefWidth="300.0" promptText="Tìm kiếm hóa đơn..." />
                        <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #3498db;" text="Tìm kiếm" textFill="white" />
                        <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #95a5a6;" text="Làm mới" textFill="white" />
                        <Button fx:id="btnExport" mnemonicParsing="false" onAction="#handleExport" style="-fx-background-color: #27ae60;" text="Xuất Excel" textFill="white" />
                    </children>
                </HBox>

                <TableView fx:id="tableInvoices" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaHD" prefWidth="80.0" text="Mã HĐ" />
                        <TableColumn fx:id="colNgayLap" prefWidth="120.0" text="Ngày lập" />
                        <TableColumn fx:id="colKhachHang" prefWidth="150.0" text="Khách hàng" />
                        <TableColumn fx:id="colNhanVien" prefWidth="120.0" text="Nhân viên" />
                        <TableColumn fx:id="colTongTien" prefWidth="120.0" text="Tổng tiền" />
                        <TableColumn fx:id="colGiamGia" prefWidth="80.0" text="Giảm giá" />
                        <TableColumn fx:id="colThanhToan" prefWidth="120.0" text="Thanh toán" />
                        <TableColumn fx:id="colTrangThai" prefWidth="100.0" text="Trạng thái" />
                        <TableColumn fx:id="colHanhDong" prefWidth="100.0" text="Hành động" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
