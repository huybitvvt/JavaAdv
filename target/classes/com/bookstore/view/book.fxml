<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.controller.BookController">
    <children>
        <VBox spacing="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 20 0 20;">
                    <children>
                        <Label text="QUẢN LÝ SÁCH" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <!-- Toolbar -->
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
                    <children>
                        <TextField fx:id="txtSearch" prefWidth="250.0" promptText="Tìm kiếm sách..." />
                        <ComboBox fx:id="cboCategory" prefWidth="150.0" promptText="Tất cả thể loại" />
                        <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #3498db;" text="Tìm kiếm" textFill="white" />
                        <Button fx:id="btnAdvancedSearch" mnemonicParsing="false" onAction="#handleAdvancedSearch" style="-fx-background-color: #9b59b6;" text="Tìm nâng cao" textFill="white" />
                        <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAdd" style="-fx-background-color: #27ae60;" text="+ Thêm mới" textFill="white" />
                        <Button fx:id="btnExport" mnemonicParsing="false" onAction="#handleExport" style="-fx-background-color: #e67e22;" text="Xuất Excel" textFill="white" />
                        <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #95a5a6;" text="Làm mới" textFill="white" />
                    </children>
                </HBox>

                <!-- Table -->
                <TableView fx:id="tableBooks" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaSach" prefWidth="60.0" text="Mã" />
                        <TableColumn fx:id="colTenSach" prefWidth="250.0" text="Tên sách" />
                        <TableColumn fx:id="colTacGia" prefWidth="150.0" text="Tác giả" />
                        <TableColumn fx:id="colNXB" prefWidth="120.0" text="NXB" />
                        <TableColumn fx:id="colTheLoai" prefWidth="100.0" text="Thể loại" />
                        <TableColumn fx:id="colNamXB" prefWidth="80.0" text="Năm XB" />
                        <TableColumn fx:id="colGiaBia" prefWidth="100.0" text="Giá bìa" />
                        <TableColumn fx:id="colSoLuong" prefWidth="80.0" text="Tồn kho" />
                        <TableColumn fx:id="colHanhDong" prefWidth="150.0" text="Hành động" />
                    </columns>
                </TableView>

                <!-- Status -->
                <HBox alignment="CENTER_LEFT" prefHeight="30.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 10 0 10;">
                    <children>
                        <Label fx:id="lblTotal" text="Tổng số: 0" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Số dòng/trang:" />
                                <ComboBox fx:id="cboPageSize" prefWidth="80.0" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <Pagination fx:id="pagination" VBox.vgrow="NEVER" />
            </children>
        </VBox>
    </children>
</AnchorPane>
