<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.controller.CustomerController">
    <children>
        <VBox spacing="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 20 0 20;">
                    <children>
                        <Label text="QUẢN LÝ KHÁCH HÀNG" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
                    <children>
                        <TextField fx:id="txtSearch" prefWidth="250.0" promptText="Tìm kiếm khách hàng..." />
                        <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #3498db;" text="Tìm kiếm" textFill="white" />
                        <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAdd" style="-fx-background-color: #27ae60;" text="+ Thêm mới" textFill="white" />
                        <Button fx:id="btnExport" mnemonicParsing="false" onAction="#handleExport" style="-fx-background-color: #e67e22;" text="Xuất Excel" textFill="white" />
                        <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #95a5a6;" text="Làm mới" textFill="white" />
                    </children>
                </HBox>

                <TableView fx:id="tableCustomers" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaKH" prefWidth="50.0" text="Mã" />
                        <TableColumn fx:id="colHoTen" prefWidth="180.0" text="Họ tên" />
                        <TableColumn fx:id="colGioiTinh" prefWidth="80.0" text="Giới tính" />
                        <TableColumn fx:id="colNgaySinh" prefWidth="100.0" text="Ngày sinh" />
                        <TableColumn fx:id="colSDT" prefWidth="120.0" text="Số điện thoại" />
                        <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email" />
                        <TableColumn fx:id="colDiaChi" prefWidth="180.0" text="Địa chỉ" />
                        <TableColumn fx:id="colDiem" prefWidth="80.0" text="Điểm" />
                        <TableColumn fx:id="colHanhDong" prefWidth="120.0" text="Hành động" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
