<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.controller.CustomerDialogController">
    <children>
        <VBox spacing="15" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="THÔNG TIN KHÁCH HÀNG" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <GridPane hgap="10" vgap="10">
                    <children>
                        <Label text="Họ tên:" />
                        <TextField fx:id="txtHoTen" GridPane.columnIndex="1" />

                        <Label text="Giới tính:" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cboGioiTinh" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Ngày sinh:" GridPane.rowIndex="2" />
                        <DatePicker fx:id="dpNgaySinh" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Số điện thoại:" GridPane.rowIndex="3" />
                        <TextField fx:id="txtSDT" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Email:" GridPane.rowIndex="4" />
                        <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label text="Địa chỉ:" GridPane.rowIndex="5" />
                        <TextField fx:id="txtDiaChi" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Lưu" />
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Hủy" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
