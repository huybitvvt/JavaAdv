<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.controller.BookDialogController">
    <children>
        <VBox spacing="15" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="THÔNG TIN SÁCH" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <GridPane hgap="10" vgap="5">
                    <children>
                        <Label text="Tên sách:" />
                        <TextField fx:id="txtTenSach" GridPane.columnIndex="1" />
                        <Label fx:id="lblErrorTenSach" text="" textFill="#e74c3c" GridPane.columnIndex="2" />

                        <Label text="Tác giả:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtTacGia" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Nhà xuất bản:" GridPane.rowIndex="2" />
                        <TextField fx:id="txtNXB" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Thể loại:" GridPane.rowIndex="3" />
                        <ComboBox fx:id="cboTheLoai" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Năm xuất bản:" GridPane.rowIndex="4" />
                        <TextField fx:id="txtNamXB" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <Label fx:id="lblErrorNamXB" text="" textFill="#e74c3c" GridPane.columnIndex="2" GridPane.rowIndex="4" />

                        <Label text="Giá bìa:" GridPane.rowIndex="5" />
                        <TextField fx:id="txtGiaBia" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <Label fx:id="lblErrorGiaBia" text="" textFill="#e74c3c" GridPane.columnIndex="2" GridPane.rowIndex="5" />

                        <Label text="Số lượng tồn:" GridPane.rowIndex="6" />
                        <TextField fx:id="txtSoLuongTon" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <Label fx:id="lblErrorSoLuong" text="" textFill="#e74c3c" GridPane.columnIndex="2" GridPane.rowIndex="6" />

                        <Label text="Mô tả:" GridPane.rowIndex="7" />
                        <TextArea fx:id="txtMoTa" GridPane.columnIndex="1" GridPane.rowIndex="7" prefRowCount="3" GridPane.columnSpan="2" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Lưu" />
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Hủy" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
